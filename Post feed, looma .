* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: #1a0a02;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #fff;
  max-width: 480px;
  margin: 0 auto;
  min-height: 100vh;
}

.app {
  padding-bottom: 70px;
}

/* Top Nav */
.topnav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(26,10,2,0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.logo {
  font-size: 26px;
  font-weight: 700;
  letter-spacing: -1px;
  background: linear-gradient(135deg, #F0C060, #D4762A);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.nav-icons {
  display: flex;
  gap: 8px;
}

.icon-btn {
  background: none;
  border: none;
  color: rgba(255,255,255,0.7);
  cursor: pointer;
  padding: 6px;
  border-radius: 50%;
  transition: color 0.2s;
}

.icon-btn:hover { color: #F0C060; }

/* Feed */
.feed {
  display: flex;
  flex-direction: column;
}

/* Post Component */
.post {
  border-bottom: 1px solid rgba(255,255,255,0.06);
  padding-bottom: 8px;
  margin-bottom: 8px;
}

.post-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
}

.post-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.avatar-placeholder {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B3A2A, #D4762A);
  flex-shrink: 0;
}

.post-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 5px;
}

.username {
  font-size: 13px;
  font-weight: 700;
  color: #fff;
}

.verified {
  font-size: 11px;
  color: #F0C060;
  font-weight: 700;
}

.skills-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

.skill {
  font-size: 10px;
  color: #F0C060;
  font-weight: 500;
  background: rgba(240,192,96,0.12);
  padding: 2px 6px;
  border-radius: 10px;
  border: 1px solid rgba(240,192,96,0.2);
}

.follow-btn {
  background: transparent;
  border: 1px solid #F0C060;
  color: #F0C060;
  border-radius: 20px;
  padding: 5px 14px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.follow-btn:hover {
  background: #F0C060;
  color: #3B1408;
}

/* Carousel */
.carousel {
  position: relative;
  overflow: hidden;
  width: 100%;
}

.carousel-track {
  display: flex;
  transition: transform 0.35s ease;
}

.carousel-slide {
  min-width: 100%;
}

.post-image {
  width: 100%;
  height: 380px;
  background: rgba(255,255,255,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  color: rgba(255,255,255,0.2);
  font-size: 13px;
}

.cat-tag {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(8px);
  color: #F0C060;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid rgba(240,192,96,0.3);
}

.price-tag {
  position: absolute;
  bottom: 12px;
  right: 12px;
  background: linear-gradient(135deg, #F0C060, #D4762A);
  color: #3B1408;
  font-size: 13px;
  font-weight: 700;
  padding: 5px 12px;
  border-radius: 20px;
}

.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 5px;
  padding: 8px 0;
}

.cdot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: all 0.3s;
}

.cdot.active {
  background: #F0C060;
  width: 18px;
  border-radius: 3px;
}

/* Actions */
.post-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 14px;
}

.left-actions {
  display: flex;
  align-items: center;
  gap: 14px;
}

.action-btn {
  background: none;
  border: none;
  color: rgba(255,255,255,0.7);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  padding: 4px;
  transition: color 0.2s;
}

.action-btn:hover { color: #F0C060; }

.action-btn.liked svg {
  fill: #ff6b6b;
  stroke: #ff6b6b;
  color: #ff6b6b;
}

.action-btn.pinned svg {
  fill: #F0C060;
  stroke: #F0C060;
  color: #F0C060;
}

.post-caption {
  padding: 4px 14px;
  font-size: 13px;
  color: rgba(255,255,255,0.75);
  line-height: 1.5;
}

.post-caption .username {
  font-weight: 700;
  margin-right: 5px;
}

.view-comments {
  padding: 5px 14px;
  font-size: 12px;
  color: rgba(255,255,255,0.3);
  cursor: pointer;
}

.view-comments:hover { color: #F0C060; }

.cart-btn {
  margin: 8px 14px;
  width: calc(100% - 28px);
  background: linear-gradient(135deg, #F0C060, #D4762A);
  color: #3B1408;
  border: none;
  border-radius: 50px;
  padding: 12px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.2s;
}

.cart-btn:hover { opacity: 0.9; }

/* Bottom Nav */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 480px;
  background: rgba(26,10,2,0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-around;
  padding: 10px 0 16px;
  z-index: 100;
}

.nav-btn {
  background: none;
  border: none;
  color: rgba(255,255,255,0.35);
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  font-size: 10px;
  font-weight: 500;
  transition: color 0.2s;
  padding: 0 12px;
}

.nav-btn.active { color: #F0C060; }
.nav-btn:hover { color: #F0C060; }

